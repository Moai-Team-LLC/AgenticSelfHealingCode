# Copy to connectors/.env (gitignored) and fill in locally. NEVER commit the real file.
# The open-source repo ships only this template + the pure mappers in d10-instrument/adapters/.

# --- Linear (D10 incident source) ---
# Create a Personal API key: Linear → Settings → Security & access → Personal API keys.
# Read-only usage; scope to the smallest access that lists issues + history.
LINEAR_API_KEY=
# Optional: restrict the pull to one team (its key, e.g. "ENG"). Empty = all teams you can see.
LINEAR_TEAM_KEY=

# Map YOUR Linear workflow-state names to the D10 contract timestamps (issue history transitions).
# Comma-separated state names; leave empty for fields your workflow does not track (they stay undefined,
# and D10 will honestly report those incidents as non-decomposable — the point of the tool).
LINEAR_STATE_ACKNOWLEDGED=In Progress,Triage
LINEAR_STATE_CAUSE_CONFIRMED=Root Cause Found,Diagnosed
LINEAR_STATE_FIX_DEPLOYED=Deployed,Released
LINEAR_STATE_RESOLVED=Done,Completed

# --- Sentry (optional second source; detection signals only) ---
# Sentry → Settings → Auth Tokens (org-level), scope: project:read, event:read, org:read.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- App runtime (packages/app) ---
# HMAC secret that webhook senders sign the RAW body with (SECURITY-THREATMODEL §2). Use a random value.
SIGNAL_SECRET=
# Postgres + pgvector → durable state. Run `bun run migrate` once after setting it.
DATABASE_URL=
# Claude — RCA hypothesis proposer (packages/adapters). ROTATE any key ever pasted into chat before use.
ANTHROPIC_API_KEY=
# Telegram — HITL / why-trace delivery (packages/adapters). ROTATE any token ever pasted into chat.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# secret_token you set on the Telegram webhook; the /telegram/callback endpoint checks it.
TELEGRAM_WEBHOOK_SECRET=
# Sentry integration Client Secret → enables NATIVE Sentry webhooks on /webhook/sentry.
SENTRY_CLIENT_SECRET=
# A local checkout of the monitored service → real git deploy-diff grounding (CONFIRMED vs ESCALATE).
RCA_GIT_REPO=
# Token required to release the kill switch (POST /release).
KILL_RELEASE_TOKEN=

# --- Loop C — human-confirmed code repair (L1: propose → gate → human merges; NEVER auto-applies) ---
# Secret set on the GitHub `pull_request` webhook → enables /webhook/github (merge = approval).
GITHUB_WEBHOOK_SECRET=
# Fine-grained token scoped to pull-requests:write — opens the proposal PR. ROTATE any token ever pasted in chat.
GITHUB_TOKEN=
# The monitored repo the Loop C PR opens against, "owner/name".
GITHUB_REPO=
# The branch a Loop C PR targets (its base). Default: main.
GITHUB_BASE_BRANCH=main

# --- Slack (second confirm channel; approve/reject on the proposal) ---
# Bot token (xoxb-, scope chat:write). ROTATE any token ever pasted in chat.
SLACK_BOT_TOKEN=
# The channel id the proposal is posted to.
SLACK_CHANNEL=
# Signing secret → the /slack/callback endpoint verifies the `x-slack-signature` of interactive clicks.
SLACK_SIGNING_SECRET=

# --- Loop C runtime (arms the repair worker in the deployed server) ---
# HARD OPT-IN: only set to "true" when the service runs INSIDE the SECURITY-THREATMODEL §4 sandbox container
# (non-root, egress-deny, no prod secrets). The sandbox executes model-authored code — never arm it on a host.
REPAIR_ALLOW_UNTRUSTED_EXECUTION=
# A clean clone of the monitored repo the sandbox runs the grounded repro cycle against (defaults to RCA_GIT_REPO).
REPAIR_GIT_REPO=
# The test command the sandbox + gate run (space-separated argv). Default: "bun test".
REPAIR_TEST_CMD=
# The base ref to reproduce against. Default: HEAD.
REPAIR_BASE_REF=
# The accountable owner (D9) frozen into a human_approved landing, and the approver routing.
REPAIR_OWNER=
REPAIR_TEAM=
REPAIR_APPROVER=
